# Database — Supabase PostgreSQL
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-SUPABASE-PROJECT-REF].supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-SUPABASE-PROJECT-REF].supabase.co:5432/postgres"
SUPABASE_PASSWORD=""

# Auth
JWT_SECRET="replace-with-your-secret"

# Server
PORT=5001
# Frontend URL for CORS (required for production, optional for local dev)
CLIENT_URL="http://localhost:5173"

# External APIs (optional — app falls back to demo data if missing)
CRYPTOPANIC_API_KEY=""
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="deepseek/deepseek-v4-flash:free"
NEWSDATA_API_KEY=""